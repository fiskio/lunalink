#!/bin/bash
#
# Pre-commit hook for lunalink.
# Source of truth for checks is Taskfile.yml.
#

set -e

echo "Running pre-commit checks via Taskfile..."
echo ""

if ! task ci-checks; then
  echo ""
  echo "Pre-commit checks failed. Run 'task ci-checks' to reproduce."
  exit 1
fi

echo ""
echo "All pre-commit checks passed."
